{
  "name": "@isometrica/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build --tsc --tsConfigPath tsconfig.build.json",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@isometrica/config": "workspace:*",
    "@isometrica/contracts": "workspace:*",
    "@isometrica/domain": "workspace:*",
    "@neondatabase/serverless": "^1.1.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "openai": "^6.42.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0"
