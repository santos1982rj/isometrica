generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ALUNO
  PROFESSOR
  ADMIN
}

enum StatusUsuario {
  ATIVO
  BLOQUEADO
}

model User {
  id        Int            @id @default(autoincrement())
  nome      String
  email     String         @unique
  senha     String
  avatar    String?
  role      Role           @default(ALUNO)
  status    StatusUsuario  @default(ATIVO)
  xpTotal   Int            @default(0)
  nivel     Int            @default(1)
  streak    Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @default(now()) @updatedAt

  matriculas  Matricula[]
  progressos  ProgressoAula[]
  conquistas  UsuarioConquista[]
  progresso   ProgressoDiario[]
}

model Curso {
  id           Int         @id @default(autoincrement())
  titulo       String
  slug         String      @unique
  descricao    String
  resumo       String?
  imagem       String?
  preco        Float?
  publico      Boolean     @default(true)
  cargaHoraria Int?
  nivel        String      @default("INICIANTE")
  categoria    String?
  modulos      Modulo[]
  matriculas   Matricula[]
  criadoPorId  Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Modulo {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String?
  ordem     Int
  curso     Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  cursoId   Int
  aulas     Aula[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Aula {
  id        Int            @id @default(autoincrement())
  titulo    String
  slug      String
  descricao String?
  conteudo  String?
  videoUrl  String?
  duracao   Int?
  ordem     Int
  gratuito  Boolean        @default(false)
  modulo    Modulo         @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  moduloId  Int
  progressos ProgressoAula[]
  anexos    Anexo[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Anexo {
  id        Int      @id @default(autoincrement())
  nome      String
  url       String
  tipo      String
  tamanho   Int?
  aula      Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  aulaId    Int
  createdAt DateTime @default(now())
}

model Matricula {
  id            Int       @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int
  curso         Curso     @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  cursoId       Int
  status        String    @default("ATIVO")
  progresso     Float     @default(0)
  concluido     Boolean   @default(false)
  pagamentoId   String?
  valorPago     Float?
  dataConclusao DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, cursoId])
}

model ProgressoAula {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  aula           Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  aulaId         Int
  concluida      Boolean  @default(false)
  tempoAssistido Int?
  notas          String?
  concluidaEm    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, aulaId])
}

model Conquista {
  id           Int                 @id @default(autoincrement())
  titulo       String
  descricao    String
  icone        String
  cor          String
  xpRecompensa Int                 @default(10)
  createdAt    DateTime            @default(now())
  usuarios     UsuarioConquista[]
}

model UsuarioConquista {
  id              Int       @id @default(autoincrement())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          Int
  conquista       Conquista @relation(fields: [conquistaId], references: [id], onDelete: Cascade)
  conquistaId     Int
  desbloqueadaEm  DateTime  @default(now())

  @@unique([userId, conquistaId])
}

model ProgressoDiario {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  data       DateTime @default(now())
  xpGanho    Int      @default(0)
  calculos   Int      @default(0)
  exercicios Int      @default(0)

  @@unique([userId, data])
}