  "devDependencies": {
    "turbo": "^2.9.16",
    "prettier": "^3.5.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.3.0"
}
