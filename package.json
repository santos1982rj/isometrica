{
  "name": "isometrica",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma inteligente de evolução acadêmica para Engenharia",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "pnpm -r --filter=@isometrica/api --filter=@isometrica/web run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\""
